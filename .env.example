# BlueCore AI Add-On Service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8095

# Must match BlueCore gateway JWT when integrated as an add-on
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
SERVICE_AUTH_TOKEN=dev-service-token

# LLM provider: stub | ollama | openai | azure_openai
LLM_PROVIDER=stub
LLM_MODEL=bluecore-ai-v1
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Threat assessment defaults (agency policy profiles override via API)
DEFAULT_THREAT_POLICY_ID=default-officer-safety

# Audit retention (days)
AUDIT_RETENTION_DAYS=2555

# CORS — BlueCore frontends when add-on is enabled
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
